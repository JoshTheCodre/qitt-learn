# Copy to .env.local and fill in real values (.env.local is gitignored)

# Full PostgreSQL connection string
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE

# Individual connection parts
PGHOST=HOST
PGPORT=5432
PGUSER=USER
PGPASSWORD=PASSWORD
PGDATABASE=DATABASE

# Cloudflare R2 (server-side only — never NEXT_PUBLIC_*)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# Password for the /admin upload dashboard
ADMIN_PASSWORD=
